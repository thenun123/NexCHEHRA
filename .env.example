# ── fal.ai (Flux + Kling) ──────────────────────────────────────
FAL_KEY=your-key-here

# ── Mistral (LLM for prompt generation and RAG) ───────────────────────
# Get free key at: https://console.mistral.ai
MISTRAL_API_KEY=your-key-here
MISTRAL_MODEL=mistral-large-latest

# ── Flux Kontext (optional overrides) ─────────────────────────
FLUX_MODEL=fal-ai/flux-pro/kontext/max
FLUX_GUIDANCE_SCALE=2.0
FLUX_INFERENCE_STEPS=28
FLUX_SAFETY_TOLERANCE=2
FLUX_MULTI_MODEL=fal-ai/flux-pro/kontext/max/multi

# ── Kling (optional overrides) ────────────────────────────────
KLING_MODEL=fal-ai/kling-video/v1.6/pro/image-to-video
# Options: audio_off | audio_on | voice_control
KLING_AUDIO_MODE=audio_on
# Required if KLING_AUDIO_MODE=voice_control (otherwise ignored)
# KLING_VOICE_ID=

# ── Supabase (Postgres) ─────────────────────────────────────────
# Get from Supabase project → Settings → Database → Connection string (URI, use the
# "Session pooler" one on port 6543 for Render, not the direct 5432 one)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[HOST]:6543/postgres

# ── ImageKit (media storage/CDN) ─────────────────────────────────
# Get from ImageKit dashboard → Developer options
IMAGEKIT_PUBLIC_KEY=your-public-key
IMAGEKIT_PRIVATE_KEY=your-private-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
# Root folder inside ImageKit where everything gets mirrored to
IMAGEKIT_ROOT_FOLDER=nexchehra

# ── App ────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-in-prod
FLASK_PORT=5000
FLASK_DEBUG=true
REFERENCE_IMAGE_PATH=static/images/aira.jpg
OUTPUT_DIR=static/outputs
DEFAULT_ASPECT_RATIO=16:9
